  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to the administration of the government; repealing and terminating the Wyoming business council; repealing the Wyoming Economic Development Act and renumbering portions of the act; specifying requirements and conditions for the repeal and termination; transferring specified functions of the Wyoming business council to other state entities; making conforming amendments; repealing obsolete provisions; requiring reports; specifying applicability; authorizing positions; providing an appropriation; and providing for effective dates."
    }
  ],
