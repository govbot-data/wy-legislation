  "identifier": "HB0028",
  "title": "Sexual exploitation of children-amendments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to crimes and offenses; amending the definition of explicit sexual conduct for the purposes of the crime of sexual exploitation of children; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act expands the definition of \"explicit sexual conduct\" to include conduct involving the chest or breasts of a female person."
    }
  ],
