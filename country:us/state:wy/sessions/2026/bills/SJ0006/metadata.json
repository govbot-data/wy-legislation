  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "A JOINT RESOLUTION designating April 26 of each year to be shared parenting day in the state of Wyoming."
    },
    {
      "note": "summary",
      "abstract": "This joint resolution establishes April 26 of each year as Shared Parenting Day in Wyoming. The resolution explains the importance of shared parenting and the need for children to have good relationships with both parents who are fit caregivers."
    }
  ],
  "other_titles": [
