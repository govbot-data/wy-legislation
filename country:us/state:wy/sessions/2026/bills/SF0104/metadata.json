  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to higher education; providing funding for specified research projects at the University of Wyoming; allocating revenue generated by research as specified; specifying conditions and permitted uses for appropriated funds; authorizing fundraising to support research projects; requiring nonstate matching funds as specified; creating an account; requiring reports; providing appropriations; and providing for an effective date."
    }
  ],
