  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to highways; creating the interstate highways traffic study task force; specifying members and duties of the task force; providing a termination date for the task force; requiring reports; providing for the planning, design and construction of highways as specified; authorizing investment of state funds in transportation construction loans; providing a funding guarantee by modifying the distribution of revenues; providing appropriations; providing for the transfer of funds; and providing for an effective date."
    }
  ],
