{
  "legislative_session": "2026",
  "identifier": "HB0112",
  "title": "Riverton state office task force-sunset.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to state funded capital construction; terminating a task force; depositing unexpended funds as specified; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act terminates the Riverton State Office Task Force on April 1, 2026, instead of June 30, 2028, as was originally established under 2023 Wyoming Session Laws, Chapter 187. The Act also reverts unexpended funds from the fifty thousand dollars ($50,000.00) appropriation for the Task Force to the Legislative Stabilization Reserve Account on June 30, 2026."
    }
  ],
