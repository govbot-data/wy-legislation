{
  "legislative_session": "2026",
  "identifier": "SF0013",
  "title": "Wyoming national guard member referral-amendments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to defense forces and affairs; increasing the referral bonus amount for the Wyoming national guard member referral incentive program; expanding eligibility of the program; extending the sunset date for the program; making conforming amendments; providing an appropriation; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act expands the eligibility for the Wyoming National Guard Member Referral Incentive Program to veterans of the Wyoming National Guard, current employees of the Wyoming Military Department, and recruits beginning the enlistment process with the Wyoming National Guard. This act prohibits the Wyoming Military Department from distributing a referral bonus to a referring recruit until the referring recruit has completed accession into the Wyoming National Guard. This act increases the referral bonus amount from five hundred dollars ($500.00) to one thousand dollars ($1,000.00), extends the sunset date of the program from July 1, 2026 to July 1, 2028, and provides an appropriation of two hundred fifty thousand dollars ($250,000.00) from the general fund to the Wyoming Military Department for purposes of funding the program."
    }
  ],
  "other_titles": [
