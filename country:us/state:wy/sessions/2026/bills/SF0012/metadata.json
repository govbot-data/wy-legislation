{
  "legislative_session": "2026",
  "identifier": "SF0012",
  "title": "Wyoming national guard reenlistment bonus program.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to defense forces and affairs; creating the Wyoming national guard member reenlistment and extension program as specified; requiring reporting; requiring rulemaking; providing an appropriation; and providing for effective dates."
    },
    {
      "note": "summary",
      "abstract": "This act creates the Wyoming National Guard Member Reenlistment and Extension Program that is administered by the Wyoming Military Department. This program provides a reenlistment or extension bonus of not more than five thousand dollars ($5,000.00) to a Wyoming National Guard member who satisfies the Wyoming National Guard's reenlistment or extension eligibility criteria, reenlists or extends with the Wyoming National Guard for not less than three (3) years, and satisfies any other requirements specified by the Wyoming Military Department. This act appropriates one million dollars ($1,000,000.00) from the general fund to the Wyoming Military Department for purposes of funding the Wyoming National Guard Member Reenlistment and Extension Program. Comments: This act requires the Wyoming Military Department to annually report to the Joint Transportation, Highways and Military Affairs Interim Committee on the Wyoming National Guard Member Reenlistment and Extension Program."
    }
  ],
