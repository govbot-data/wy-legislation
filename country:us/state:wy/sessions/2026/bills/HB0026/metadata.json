{
  "legislative_session": "2026",
  "identifier": "HB0026",
  "title": "Vehicle registration fees-tribal governments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to motor vehicles; exempting motor vehicles owned by tribal governments from paying county and state registration fees; requiring the department of transportation to issue distinctive license plates for vehicles owned by tribal governments; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act exempts motor vehicles owned by the tribal governments of the Eastern Shoshone and Northern Arapaho tribes of the Wind River Indian Reservation from paying county and state motor vehicle registration fees. This act requires the Wyoming Department of Transportation to issue distinctive license plates that indicate public ownership for motor vehicles owned by the tribal governments of the Eastern Shoshone and Northern Arapaho tribes of the Wind River Indian Reservation."
    }
  ],
  "other_titles": [
