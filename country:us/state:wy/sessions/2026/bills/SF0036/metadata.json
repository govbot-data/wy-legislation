  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to the Hathaway scholarship program; amending award timing for the Hathaway scholarship program; amending eligibility requirements as specified; eliminating satisfactory academic progress requirements; eliminating continuous enrollment requirements; eliminating minimum credit hour requirements; amending the calculation of scholarship amounts; deleting obsolete language; making conforming amendments; specifying applicability; repealing provisions; and providing for an effective date."
    }
  ],
