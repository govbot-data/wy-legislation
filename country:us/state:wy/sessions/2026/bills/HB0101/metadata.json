  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to guardianship; requiring a guardian to make monthly in\u2011person monitoring of the guardian's ward; providing for reasonable fees and expenses of a guardian; requiring reporting to the court of the in\u2011person monitoring; requiring a guardian or conservator to notify specified entities of the guardian or conservator's appointment; and providing for an effective date."
    }
  ],
