  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to elections; providing for the nonpartisan nomination and election of candidates for specified county elected offices; modifying the procedure to fill vacancies for nonpartisan county elected offices; providing for the order of offices on nonpartisan election ballots; specifying the form of election ballots; making conforming amendments; repealing a conflicting provision; and providing for an effective date."
    }
  ],
