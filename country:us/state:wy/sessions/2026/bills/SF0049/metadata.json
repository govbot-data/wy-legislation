  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to public records; revising documents that constitute official public records; revising time periods for acknowledgement of public records requests and release of public records; providing for an extension of time to release public records; authorizing the ombudsman to refer a matter to the attorney general or district attorney; specifying fees for public records; increasing a penalty; authorizing attorney fees; and providing for an effective date."
    }
  ],
