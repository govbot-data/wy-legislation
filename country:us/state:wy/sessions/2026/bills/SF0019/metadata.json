{
  "legislative_session": "2026",
  "identifier": "SF0019",
  "title": "Epinephrine delivery methods.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to public health and safety; authorizing the administration of epinephrine through the use of auto-injectors, nasal sprays and any other federally approved device or method; amending definitions; requiring rulemaking; and providing for effective dates."
    },
    {
      "note": "summary",
      "abstract": "This act authorizes the administration of epinephrine through the use of auto-injectors, nasal sprays and any other federal approved device or method by school districts and other entities. The Department of Education, the Department of Health and the Board of Pharmacy are authorized to promulgate rules to implement this act."
    }
  ],
