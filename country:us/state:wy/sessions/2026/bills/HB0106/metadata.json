  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to the state forester; authorizing positions; providing for an appropriation for the forestry conservation program inmate crew; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act authorizes two (2) full-time employee positions within the State Forestry Division of the Office of State Lands and Investments, one of which is effective April 1, 2026, and one effective April 1, 2027. This act appropriates four hundred ninety\u2011nine thousand seven hundred nine dollars ($499,709.00) from the General Fund for the State Forestry Conservation Inmate Crew Program for the two (2) full-time positions, equipment and associated costs."
    }
  ],
