    {
      "note": "digest",
      "abstract": "AN ACT relating to county clerks; authorizing county clerks to seek to have frivolous filings rejected or notated as frivolous; specifying requirements and procedures for rejecting or notating frivolous filings; declaring frivolous filings to be of no legal effect; and providing for an effective date."
    }
  ],
