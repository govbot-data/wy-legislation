  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to enrollment of students in K-12 public schools; specifying the public schools of the state as being equally free and accessible to children attending school on a part\u2011time basis; specifying applicability; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "Specifies that public schools in Wyoming are equally free and accessible to all children, including those attending on a part-time basis."
    }
  ],
