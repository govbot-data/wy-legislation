  "legislative_session": "2026",
  "identifier": "SF0044",
  "title": "Gambling amendments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to crimes and offenses; amending exceptions to the offense of gambling; amending and creating definitions; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act revises the exceptions to the offense of gambling by:Limiting the exception for social gambling to those games, wagers or transactions that are incidental to a bona fide social relationship and that are conducted in private, not advertised, and in which no person receives compensation for facilitating the activity other than the direct realization of winnings.Specifying that raffles or drawings conducted for charitable purposes are an exception only when one hundred percent (100%) of the net proceeds are allocated to charitable purposes. This act revises the definition of \"profit\" to mean any financial gain. This act creates a definition of \"bona fide social relationship\" to mean a genuine social connection in which the participants have an established knowledge of each other that is not established for gambling purposes."
    }
  ],
