{
  "legislative_session": "2026",
  "identifier": "HB0005",
  "title": "Oil and gas bonding pool-investment and earnings.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to oil and gas; providing for the investment of bonding pool assessment proceeds; specifying the disposition of investment earnings; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "In 2025, the Legislature enacted a law to require the Oil and Gas Conservation Commission to create a bonding pool for oil-and-gas operators to utilize for financial assurance for, among other things, federal bonding requirements. This act requires the State Treasurer to invest funds collected for the bonding pool in accordance with law, and all investment earnings shall be deposited into the Commission's conservation fund."
    }
  ],
