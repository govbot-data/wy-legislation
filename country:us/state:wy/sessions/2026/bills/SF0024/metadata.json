{
  "legislative_session": "2026",
  "identifier": "SF0024",
  "title": "Lottery tickets-acceptance of debit card payments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to the Wyoming lottery; authorizing debit card payments for lottery ticket purchases; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "Under current law, only cash may be used to purchase lottery tickets. This act provides that debit cards may be used to purchase lottery tickets in Wyoming. Any other form of payment besides cash and debit cards is still prohibited."
    }
  ],
