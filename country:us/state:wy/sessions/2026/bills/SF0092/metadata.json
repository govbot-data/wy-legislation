  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to civil procedure; providing civil penalties for false claims made against state employees and officials as specified; providing definitions; providing exceptions; providing remedies for retaliation regarding persons who report violations of this act; providing a statute of limitations; providing procedures for lawsuits as specified; authorizing civil actions; creating an account; and providing for an effective date."
    }
  ],
