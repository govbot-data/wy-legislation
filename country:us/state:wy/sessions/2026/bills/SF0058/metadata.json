  "legislative_session": "2026",
  "identifier": "SF0058",
  "title": "Wyoming Indian Child Welfare Act sunset repeal.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to Indian child welfare; repealing the Wyoming Indian Child Welfare Act sunset date; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "Currently, the Wyoming Indian Child Welfare Act (Act) is set to sunset (automatically repeal) on July 1, 2026. This legislation repeals that provision in the Act that would sunset the Act. Consequently, the Act will no longer have a sunset date."
    }
  ],
