{
  "legislative_session": "2026",
  "identifier": "SF0067",
  "title": "Wyoming state guard-amendments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to the Wyoming state guard; removing activation of the national guard of Wyoming into service of the United States as a prerequisite for the organization of the Wyoming state guard; removing federal involvement in the Wyoming state guard; allowing the governor to organize and maintain the Wyoming state guard; making conforming amendments; providing an appropriation; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act removes the requirement that the Wyoming National Guard must be activated into the service of the United States before the Wyoming State Guard may be organized and removes federal involvement in the Wyoming State Guard. This act allows the Governor to establish and maintain the Wyoming State Guard as necessary to preserve the public peace, execute the laws of the state, suppress tumult, riot, mob or invasion, respond to emergencies within the state, support national wildland fire response or perform other duties as the Governor may require. This act authorizes the Governor to have authority over the Wyoming State Guard including its organization, strength, training, and equipment but requires the laws governing the Wyoming National Guard to be used as a model for the control and governance of the Wyoming State Guard. This act provides an appropriation of twenty-five thousand dollars ($25,000.00) from the general fund to the office of the Governor for purposes of appointing and convening a Wyoming State Council of Defense and for establishing and equipping the Wyoming State Guard as the Governor deems necessary."
    }
  ],
