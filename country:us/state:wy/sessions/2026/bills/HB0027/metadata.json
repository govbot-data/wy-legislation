  "identifier": "HB0027",
  "title": "Continuity of Permitting Act.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to cities and towns; requiring jurisdiction over pending building permit or land use applications on land annexed by a city or town to remain with the county until the applications are issued or denied by the county following annexation; requiring jurisdiction to transfer to an annexing city or town as specified; prohibiting counties from arbitrarily and capriciously denying applications for the purpose of transferring jurisdiction; specifying applicability; and providing for an effective date."
    }
  ],
  "other_titles": [
