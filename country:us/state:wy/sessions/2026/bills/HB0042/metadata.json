  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to motor vehicles; amending the elements and penalty for the failure to comply with the duty to stop vehicle where an accident involves death or personal injuries; making the penalty for failure to stop vehicle where an accident involves death or personal injuries a felony; increasing penalties; and providing for an effective date."
    }
  ],
