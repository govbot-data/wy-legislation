{
  "legislative_session": "2026",
  "identifier": "SF0046",
  "title": "Skill based amusement games-licensed liquor establishments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to gaming; limiting the licensed liquor establishments where skill based amusement games may be located; specifying applicability; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "Under existing law, skill-based amusement games may be located in specified areas in establishments that are licensed or permitted to sell alcoholic liquor or malt beverages. This act limits the licensed liquor establishments eligible for skill-based amusement games to those licensed to sell alcoholic beverages for on-premises consumption. This act requires skill-based amusement games in licensed liquor establishments to be located in areas where alcoholic beverages are sold. This act authorizes operators with existing skill-based amusement games at locations that do not meet the new definition of \"establishment\" to continue operating those games under specified conditions until the current permit expires."
    }
  ],
