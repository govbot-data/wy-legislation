{
  "legislative_session": "2026",
  "identifier": "SF0079",
  "title": "Sales and use tax reorganization.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to sales and use tax; revising the sales tax chapter to include the administration of the use tax; repealing duplicative provisions; making conforming amendments; specifying applicability; and providing for effective dates."
    },
    {
      "note": "summary",
      "abstract": "This bill revises the Wyoming Statutes related to the administration of sales and use taxes. The bill incorporates use tax administration into the sales tax chapter and repeals the use tax chapter from the Wyoming Statutes. The bill specifies that the use tax shall be administered in the same manner as the sales tax and shall be distributed in the same manner as sales taxes, subject to specific requirements. The bill includes conforming amendments and clarifies that local optional use taxes imposed before the bill's effective date will remain unaffected and continue to be administered like local optional sales taxes."
    }
  ],
