{
  "legislative_session": "2026",
  "identifier": "SF0066",
  "title": "Donated hunting licenses-amendments.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to game and fish; authorizing persons with life threatening illnesses and persons who are vision-impaired to receive donated hunting licenses as specified; requiring rulemaking; and providing for effective dates."
    },
    {
      "note": "summary",
      "abstract": "This act authorizes persons with life-threatening illnesses and vision impairment to receive donated hunting licenses. This act requires the Game and Fish Commission to promulgate all rules necessary to implement this act."
    }
  ],
