  "identifier": "SF0014",
  "title": "Literacy position for K-3 reading program.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to authorization of a full-time literacy position for the department of education; providing an appropriation; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "Appropriates $240,000 from the Public School Foundation Program Account to the Department of Education for a full-time literacy position to assist school districts in implementing a reading assessment and intervention program and language and literacy programs."
    }
  ],
