{
  "legislative_session": "2026",
  "identifier": "SF0031",
  "title": "Uniform mortgage modification act.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to mortgages; implementing the Uniform Mortgage Modification Act; specifying the priority of mortgages; specifying applicability; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This bill adopts the Uniform Mortgage Modification Act, establishing a framework for modifying mortgages and related obligations. The bill defines key terms such as \"mortgage,\" \"modification\" and \"obligation\" and specifies the types of mortgage modifications covered by the act, including changes to interest rates, payment schedules and financial covenants. The bill ensures that a mortgage retains its priority and continues to secure the obligation after a mortgage modification, without requiring re-recording. The act excludes certain modifications, such as property releases or transfers of mortgages, from the scope of the act. The bill applies the act to mortgage modifications made on or after July 1, 2026."
    }
  ],
