  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to education; providing that a person convicted of certain offenses shall not administer a home-based educational program; establishing limitations on home-based educational programs for persons under investigation for child neglect or abuse; providing penalties; making conforming amendments; specifying applicability; and providing for an effective date."
    }
  ],
