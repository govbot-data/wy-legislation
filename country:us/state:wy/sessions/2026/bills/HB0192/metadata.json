  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to motor vehicles; providing penalties for refusing chemical tests pursuant to a search warrant after an arrest for driving while under the influence; authorizing specified offenses to be used as evidence in a criminal case; requiring specified offenders to submit to substance use disorder assessments; requiring rulemaking; and providing for effective dates."
    }
  ],
