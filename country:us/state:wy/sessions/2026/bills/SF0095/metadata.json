{
  "legislative_session": "2026",
  "identifier": "SF0095",
  "title": "Driver's and motor vehicle services-third party providers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to motor vehicles; authorizing third party providers to provide driver's license and motor vehicle services as specified; creating the motor vehicle division partner program; making conforming amendments; requiring rulemaking; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act authorizes the Department of Transportation to use third party providers to provide specified driver's license and motor vehicle services. This act creates a motor vehicle division partner program to allow third party providers to conduct these services. This act requires the Department of Transportation to promulgate rules to implement this act."
    }
  ],
  "other_titles": [
