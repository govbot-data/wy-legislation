  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to civil procedure; creating the Wyoming First Amendment Protection Act; providing immunity from lawsuits based on the constitutional rights of freedom of petition, freedom of assembly, religious freedom and expression of speech; specifying procedures and limitations for lawsuits based on public participation; providing legislative findings; specifying applicability; and providing for an effective date."
    }
  ],
