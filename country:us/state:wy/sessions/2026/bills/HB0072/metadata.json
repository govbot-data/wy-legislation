  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to crimes and offenses; creating the crime of promoting obscenity to minors; amending the crime of promoting obscenity as specified; providing and amending definitions; prohibiting public school libraries and county libraries from curating materials that are harmful to minors; repealing an exemption from the crime of promoting obscenity for activities conducted in the course of employment at a school, college, university, museum or public library; repealing obsolete provisions; and providing for an effective date."
    }
  ],
  "other_titles": [
