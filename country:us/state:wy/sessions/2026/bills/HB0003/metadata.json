{
  "legislative_session": "2026",
  "identifier": "HB0003",
  "title": "Wyoming pregnancy centers-autonomy and rights.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "digest",
      "abstract": "AN ACT relating to public health and safety; providing legislative findings; prohibiting the state and specified governmental entities from adopting any law, rule or policy that targets pregnancy centers for oversight or regulation based on the centers' stance against abortion; providing definitions; providing penalties; making conforming amendments; and providing for an effective date."
    },
    {
      "note": "summary",
      "abstract": "This act prohibits the State and specified governmental entities from adopting any law, rule or policy that targets pregnancy centers for oversight or regulation based on the centers' stance against abortion. This act authorizes pregnancy centers or any person aggrieved by a violation of this act to commence a civil action."
    }
  ],
  "other_titles": [
